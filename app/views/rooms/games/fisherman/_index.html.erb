<%= turbo_frame_tag "fisherman_game_frame" do %>
    
  <div id="fisherman-game-container" data-room-code="<%= @room.code %>" data-player-id="<%= session[:player_id] %>">
    <div id="fisherman-game-master" class="relative min-h-screen bg-slate-900 text-white p-6">

      <h1 class="text-3xl font-black text-white mb-6 uppercase italic"><%= @current_player&.nickname %></h1>
      <h2 class="text-3xl font-black text-white mb-6 uppercase italic"><%= @current_player&.role %></h2>

      <% if @room.status == 'playing' %>
        <!-- 1. SPINNER (Loading) -->
        <div id="section-spinner" class="hidden flex flex-col items-center justify-center min-h-[60vh]">
          <div class="animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-purple-500"></div>
          <p class="mt-4 text-slate-400 animate-pulse">Setting up the boat...</p>
        </div>

        <!-- 2. QUESTION (Fisherman View) -->
        <% if  @current_player&.role == 'fisherman' || (@current_player&.role.nil?) %>
          <p class="text-slate-400 mb-8 italic">The fisherman reads the question, and each fish must say their answer. The fisherman needs to detect the impostor</p>
        <% end %>

        <div id="section-fisherman-control" class="<%= @current_player&.role == 'fisherman' || (@current_player&.role.nil?) ? '' : 'hidden' %> space-y-6">
          
          <div class="bg-slate-800 p-6 rounded-3xl border-2 border-yellow-500/30">
            <h2 class="text-xl font-bold text-white italic">"<%= @room.game_state['question'] %>"</h2>
          </div>

          <div class="flex justify-between items-center px-2">
            <p class="text-slate-500 text-sm font-black uppercase">Who is the impostor?</p>
            <span id="selection-count" class="bg-purple-600 text-white text-xs px-3 py-1 rounded-full font-bold">0 Selected</span>
          </div>

          <div class="grid grid-cols-1 gap-3">
            <% @room.players.where(:role.ne => 'fisherman').each do |player| %>
              <button type="button" 
                      class="suspect-card group flex justify-between items-center w-full bg-slate-800 border-2 border-slate-700 p-4 rounded-2xl transition-all active:scale-95"
                      data-player-id="<%= player.id.to_s %>">

                <div id="status-dot-<%= player.id.to_s %>" 
                class="w-3 h-3 rounded-full transition-colors duration-500 <%= player.connected? ? 'bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]' : 'bg-red-500' %>">
                </div>
                <span class="text-lg font-bold text-slate-400 group-hover:text-white transition-colors">
                  <%= player.nickname %>
                </span>

                <div class="indicator w-6 h-6 border-2 border-slate-600 rounded-lg flex items-center justify-center transition-all group-hover:border-purple-500">
                  <span class="hidden text-purple-400 font-black text-xs">✓</span>
                </div>
              </button>
            <% end %>
          </div>
          
          <% if @current_player&.role == 'fisherman' %>
            <button id="btn-lock-guess" 
                    disabled
                    class="w-full py-5 rounded-2xl bg-slate-700 text-slate-500 font-black uppercase tracking-widest transition-all">
              Select at least one
            </button>
          <% end %>
        </div>

        <!-- 3. ANSWERED (Knower View) -->
        <div id="section-knower" class="<%= @current_player&.role == 'knower' ? '' : 'hidden' %>">
          <div class="text-center">
            <h2 class="text-green-400 font-black text-3xl mb-2">YOU ARE A KNOWER</h2>
            <p class="text-slate-400 mb-8 italic">Don't let the impostor hear you!</p>
            
            <div class="bg-gradient-to-br from-green-500/20 to-emerald-500/10 p-12 rounded-[3rem] border-4 border-green-500/30 mb-8">
              <p class="text-xs font-bold tracking-widest text-green-500 mb-2">THE SECRET ANSWER IS</p>
              <h3 class="text-5xl font-black"><%= @room.game_state['answereds'].sample %></h3>
            </div>
          </div>
        </div>

        <!-- 4. IMPOSTOR (Impostor View) -->
        <div id="section-impostor" class="<%= @current_player&.role == 'impostor' ? '' : 'hidden' %>">
          <div class="text-center">
            <h2 class="text-red-500 font-black text-3xl mb-2">YOU ARE THE IMPOSTOR</h2>
            <p class="text-slate-400 mb-8">Listen to the question and blend in!</p>
            
            <div class="bg-red-500/10 p-12 rounded-[3rem] border-4 border-dashed border-red-500/30 mb-8">
              <h3 class="text-3xl font-black text-red-500">???</h3>
              <p class="text-xs text-red-400 mt-2">You don't know the word! - Invent a clever lie</p>
            </div>
          </div>
        </div>
      <% elsif @room.status == 'finished' %>
        <!-- 5. RESULTS -->
        <div id="section-results">
          <h2 class="text-4xl font-black text-center mb-10 bg-gradient-to-r from-yellow-400 to-orange-500 bg-clip-text text-transparent italic">LEADERBOARD</h2>
          <div class="space-y-4">
            <% @room.game_state['sorted_players'].each_with_index do |player, index| %>
              
    
              <div class="flex items-center justify-between p-5 rounded-2xl border-2 transition-all
                          <%= index == 0 ? 'animate-bounce bg-yellow-400/10 border-yellow-400 shadow-[0_0_15px_rgba(250,204,21,0.2)]' : 'bg-slate-800 border-slate-700' %>">
                
                <div class="flex items-center gap-4">
                  <!-- Rank Number -->
                  <span class="text-2xl font-black <%= index == 0 ? 'text-yellow-400' : 'text-slate-500' %>">
                    #<%= index + 1 %>
                  </span>
                  
                  <div>
                    <p class="font-bold text-lg <%= index == 0 ? 'text-white' : 'text-slate-300' %>">
                      <%= player.dig("nickname") %>
                      <% if index == 0 %> <span class="ml-2">👑</span> <% end %>
                    </p>
                  </div>
                </div>

                <!-- Points Display -->
                <div class="text-right">
                  <p class="text-2xl font-mono font-black <%= index == 0 ? 'text-yellow-400' : 'text-purple-400' %>">
                    <%= player.dig("points") %>
                  </p>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Points</p>
                </div>
              </div>

            <% end %>
          </div>

          <div class="mt-10 pb-8">
            <button id="btn-restart-game" 
                    class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-black py-5 rounded-2xl shadow-xl transform transition-all active:scale-95 uppercase tracking-[0.2em]">
              🎮 Play Again
            </button>
            
            <p class="text-center text-slate-500 text-xs mt-4 font-bold uppercase tracking-widest">
              Resets all points and starts a new round
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>


<div id="fisherman-game-container" data-room-code="<%= @room.code %>" data-player-id="<%= session[:player_id] %>">
  <div id="fisherman-game-master" class="relative min-h-screen bg-slate-900 text-white p-6">

    <!-- 1. SPINNER (Loading) -->
    <div id="section-spinner" class=" flex flex-col items-center justify-center min-h-[60vh]">
      <div class="animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-purple-500"></div>
      <p class="mt-4 text-slate-400 animate-pulse">Setting up the boat...</p>
    </div>

    <!-- 2. QUESTION (Fisherman View) -->
    <div id="section-question" class="">
      <h2 class="text-2xl font-black text-center mb-8 text-yellow-400">ASK YOUR QUESTION</h2>
      <div class="bg-slate-800 p-6 rounded-3xl border-2 border-slate-700 shadow-xl">
        <textarea id="fisherman-input" placeholder="e.g. What does it look like?" class="w-full bg-slate-900 rounded-xl p-4 border-2 border-slate-700 focus:border-yellow-400 outline-none text-lg"></textarea>
        
        <div class="mt-8">
          <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 text-center">Current Players</p>
          <div class="flex flex-wrap justify-center gap-3">
            <% @room.players.each do |p| %>
              <span class="px-4 py-2 bg-slate-700 rounded-full text-sm font-bold border border-slate-600"><%= p.nickname %></span>
            <% end %>
          </div>
        </div>
        
        <button class="w-full mt-8 bg-yellow-400 text-slate-900 font-black py-4 rounded-xl shadow-lg hover:scale-105 transition-transform">
          SEND TO EVERYONE
        </button>
      </div>
    </div>

    <!-- 3. ANSWERED (Knower View) -->
    <div id="section-knower" class="">
      <div class="text-center">
        <h2 class="text-green-400 font-black text-3xl mb-2">YOU ARE A KNOWER</h2>
        <p class="text-slate-400 mb-8 italic">Don't let the impostor hear you!</p>
        
        <div class="bg-gradient-to-br from-green-500/20 to-emerald-500/10 p-12 rounded-[3rem] border-4 border-green-500/30 mb-8">
          <p class="text-xs font-bold tracking-widest text-green-500 mb-2">THE SECRET WORD IS</p>
          <h3 class="text-5xl font-black"><%= @room.game_state['secret_word'] %></h3>
        </div>
        
        <input type="text" placeholder="Write your response..." class="w-full bg-slate-800 border-2 border-slate-700 rounded-2xl p-4 text-center text-xl font-bold">
      </div>
    </div>

    <!-- 4. IMPOSTOR (Impostor View) -->
    <div id="section-impostor" class="">
      <div class="text-center">
        <h2 class="text-red-500 font-black text-3xl mb-2">YOU ARE THE IMPOSTOR</h2>
        <p class="text-slate-400 mb-8">Listen to the question and blend in!</p>
        
        <div class="bg-red-500/10 p-12 rounded-[3rem] border-4 border-dashed border-red-500/30 mb-8">
          <h3 class="text-3xl font-black text-red-500">???</h3>
          <p class="text-xs text-red-400 mt-2">You don't know the word!</p>
        </div>

        <input type="text" placeholder="Invent a clever lie..." class="w-full bg-slate-800 border-2 border-red-900/30 rounded-2xl p-4 text-center text-xl font-bold text-red-200">
      </div>
    </div>

    <!-- 5. RESULTS -->
    <div id="section-results" class="">
      <h2 class="text-4xl font-black text-center mb-10 bg-gradient-to-r from-yellow-400 to-orange-500 bg-clip-text text-transparent italic">LEADERBOARD</h2>
      <div class="space-y-4">
        <% @room.players.each_with_index do |p, i| %>
          <div class="flex justify-between items-center bg-slate-800 p-5 rounded-2xl border-l-8 <%= i == 0 ? 'border-yellow-400 shadow-lg shadow-yellow-400/10' : 'border-slate-600' %>">
            <span class="text-xl font-bold"><%= i + 1 %>. <%= p.nickname %></span>
            <span class="bg-slate-900 px-4 py-1 rounded-full font-mono text-purple-400"><%= 0 %> pts</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

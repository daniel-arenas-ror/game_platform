<div class="space-y-6 bg-slate-900/50 p-6 rounded-2xl border border-slate-700">

  <div>
    <label class="block text-xs font-bold text-slate-400 mb-3 tracking-widest">NUMBER OF ROUNDS</label>
    <div class="grid grid-cols-3 gap-3">
      <% [3, 5, 10].each do |num| %>
        <label class="relative cursor-pointer">
          <input type="radio" name="room[game_state][total_rounds]" value="<%= num %>" 
                 class="peer hidden" <%= 'checked' if @room.game_state['total_rounds'].to_i == num %>>
          <div class="text-center py-3 bg-slate-800 border-2 border-slate-700 rounded-xl text-white font-bold 
                      peer-checked:border-purple-500 peer-checked:bg-purple-500/10 transition-all">
            <%= num %> Rounds
          </div>
        </label>
      <% end %>
    </div>
  </div>
</div>

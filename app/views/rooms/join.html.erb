<div class="bg-slate-900 min-h-screen flex items-center justify-center p-6">
  <div class="max-w-sm w-full bg-slate-800 rounded-3xl p-8 border border-slate-700 shadow-2xl text-center">
    
    <div class="mb-8">
      <div class="text-5xl mb-4">🎮</div>
      <h1 class="text-2xl font-bold text-white">Join <%= @game.name %></h1>
      <p class="text-slate-400">Room Code: <span class="text-purple-400 font-mono font-bold"><%= @room.code %></span></p>
    </div>

    <%= form_with url: submit_join_path(@room.code), method: :post, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :nickname, "YOUR NICKNAME", class: "block text-xs font-black text-slate-500 mb-2 tracking-widest" %>
        <%= f.text_field :nickname, 
            placeholder: "e.g. Player 1", 
            maxlength: 12,
            autofocus: true,
            class: "w-full bg-slate-900 border-2 border-slate-700 rounded-xl px-4 py-3 text-white text-center focus:border-purple-500 focus:outline-none transition-colors font-bold text-lg" 
        %>
      </div>

      <%= f.submit "ENTER LOBBY", class: "w-full bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 text-white font-black py-4 rounded-xl shadow-lg transition-transform active:scale-95 cursor-pointer" %>
    <% end %>

    <p class="mt-8 text-slate-500 text-xs uppercase tracking-tighter">
      Wait for the host to start the game
    </p>
  </div>
</div>

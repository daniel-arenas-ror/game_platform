<!-- app/views/rooms/show.html.erb -->
<div class="bg-slate-900 min-h-screen text-white p-8 flex flex-col items-center">
  <div class="max-w-4xl w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    
    <!-- Left Side: Game Info & QR -->
    <div class="text-center md:text-left">
      <h1 class="text-4xl font-black mb-2"><%= @game.name %></h1>
      <p class="text-purple-400 font-mono text-2xl mb-8">ROOM: <%= @room.code %></p>
      
      <div class="bg-white p-4 rounded-2xl inline-block mb-4 shadow-2xl">
        <%= @svg.html_safe %>
      </div>
      
      <p class="text-slate-400">Scan to join the game</p>
      <p class="text-xs text-slate-500 mt-2"><%= @join_url %></p>
    </div>

    <!-- Right Side: Player List (ActionCable will update this later) -->
    <div class="bg-slate-800 rounded-3xl p-8 border border-slate-700 shadow-xl min-h-[400px]">
      <h2 class="text-xl font-bold mb-6 flex justify-between">
        Players 
        <span class="bg-purple-600 text-xs py-1 px-3 rounded-full">Waiting...</span>
      </h2>
      
      <div id="player-list" data-room-code="<%= @room.code %>" class="space-y-4">
        <!-- We will inject players here with ActionCable -->
        <% @room.players.each do |player| %>
            <div class="flex items-center space-x-4 bg-slate-700 p-4 rounded-xl border border-slate-600">
            <div class="w-10 h-10 bg-purple-500 rounded-full flex items-center justify-center font-bold">
                <%= player.nickname[0].upcase %>
            </div>
            <div class="text-white font-bold"><%= player.nickname %></div>
            </div>
        <% end %>
        <div class="flex items-center space-x-4 bg-slate-700/50 p-4 rounded-xl border border-slate-600 animate-pulse">
          <div class="w-10 h-10 bg-slate-600 rounded-full"></div>
          <div class="h-4 w-32 bg-slate-600 rounded"></div>
        </div>
      </div>

      <button class="w-full mt-12 bg-green-500 hover:bg-green-400 text-slate-900 font-black py-4 rounded-xl uppercase tracking-widest transition-all">
        Start Game
      </button>
    </div>

  </div>
</div>
